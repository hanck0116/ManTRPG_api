{
  "name": "mantrpg-api",
  "version": "0.1.0",
  "description": "Token-efficient TRPG engine/API scaffold based on ManRPG V18 rule sources.",
  "type": "module",
  "scripts": {
    "dev:server": "tsx src/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "worker:check": "tsc --noEmit --lib ES2022,WebWorker worker/index.ts"
  },
  "devDependencies": {
    "tsx": "^4.20.4",
    "typescript": "^5.5.3",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
